<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="device-service"/>

    <!-- 引入通用配置 -->
    <include resource="classpath:logback-spring.xml" optional="true"/>

    <!-- 服务特定日志级别 -->
    <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
    <logger name="org.springframework.kafka" level="INFO"/>
    <logger name="org.redisson" level="INFO"/>

    <!-- 开发环境：使用可读格式输出到控制台 -->
    <springProfile name="dev,local">
        <!-- 降低 Spring 框架日志级别，显示启动信息 -->
        <logger name="org.springframework.boot" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.springframework.data" level="DEBUG"/>

        <root level="DEBUG">
            <appender-ref ref="ASYNC_PRETTY"/>
        </root>
    </springProfile>

    <!-- 生产环境：使用 JSON 格式输出（由容器采集） -->
    <springProfile name="prod,k8s">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>

    <!-- 测试环境：使用 JSON 格式输出 -->
    <springProfile name="test">
        <root level="DEBUG">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>
</configuration>
