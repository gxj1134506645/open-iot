<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <!-- 服务名称 -->
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="connect-service"/>
    <springProperty scope="context" name="ENV" source="spring.profiles.active" defaultValue="dev"/>

    <!-- ======================================== -->
    <!-- 控制台输出 (可读格式 - 开发环境) -->
    <!-- ======================================== -->
    <appender name="PRETTY_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-N/A}] [%X{tenantId:-N/A}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!-- 控制台输出 (JSON 格式) -->
    <!-- ======================================== -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeCallerData>true</includeCallerData>
            <customFields>{"service":"${SERVICE_NAME}","env":"${ENV}"}</customFields>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!-- 异步 Appender (提升性能) -->
    <!-- ======================================== -->
    <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <appender name="ASYNC_PRETTY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="PRETTY_CONSOLE"/>
    </appender>

    <!-- 服务特定日志级别 -->
    <logger name="io.netty" level="INFO"/>
    <logger name="org.springframework.kafka" level="INFO"/>
    <logger name="com.openiot.connect" level="DEBUG"/>

    <!-- 开发环境：使用可读格式输出到控制台 -->
    <springProfile name="dev,local">
        <!-- Spring Boot 启动日志 -->
        <logger name="org.springframework.boot" level="INFO"/>
        <logger name="org.springframework.boot.autoconfigure" level="INFO"/>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.kafka" level="INFO"/>

        <root level="DEBUG">
            <appender-ref ref="ASYNC_PRETTY"/>
        </root>
    </springProfile>

    <!-- 生产环境：使用 JSON 格式输出（由容器采集） -->
    <springProfile name="prod,k8s">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>

    <!-- 测试环境：使用 JSON 格式输出 -->
    <springProfile name="test">
        <root level="DEBUG">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>
</configuration>
