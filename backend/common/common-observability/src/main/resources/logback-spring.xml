<?xml version="1.0" encoding="UTF-8"?>
<!--
========================================
OpenIoT 通用 Logback 配置模板
========================================
提供结构化 JSON 日志输出，包含：
- traceId: 链路追踪 ID
- tenantId: 租户 ID
- service: 服务名称
- level: 日志级别
- message: 日志消息
========================================
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- 从环境变量读取服务名 -->
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="unknown"/>
    <!-- 从环境变量读取环境 -->
    <springProperty scope="context" name="ENV" source="spring.profiles.active" defaultValue="dev"/>

    <!-- ======================================== -->
    <!-- 控制台输出 (JSON 格式) -->
    <!-- ======================================== -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 时间戳格式 -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>

            <!-- 包含 MDC 中的字段 -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>parentId</includeMdcKeyName>

            <!-- 包含调用者信息 -->
            <includeCallerData>true</includeCallerData>

            <!-- 自定义字段 -->
            <customFields>{"service":"${SERVICE_NAME}","env":"${ENV}"}</customFields>

            <!-- 字段命名 -->
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>@version</version>
                <message>message</message>
                <logger>logger_name</logger>
                <thread>thread_name</thread>
                <level>level</level>
                <levelValue>[ignore]</levelValue>
            </fieldNames>

            <!-- 异常堆栈格式 -->
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>30</maxDepthPerThrowable>
                <maxLength>2048</maxLength>
                <shortenedClassNameLength>20</shortenedClassNameLength>
                <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!-- 控制台输出 (可读格式 - 开发环境) -->
    <!-- ======================================== -->
    <appender name="PRETTY_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-N/A}] [%X{tenantId:-N/A}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!-- 异步 Appender (提升性能) -->
    <!-- ======================================== -->
    <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <appender name="ASYNC_PRETTY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="PRETTY_CONSOLE"/>
    </appender>

    <!-- ======================================== -->
    <!-- 敏感信息过滤器 -->
    <!-- ======================================== -->
    <turboFilter class="ch.qos.logback.classic.turbo.MarkerFilter">
        <Name>SENSITIVE_FILTER</Name>
        <onMatch>DENY</onMatch>
        <marker>SENSITIVE</marker>
    </turboFilter>

    <!-- ======================================== -->
    <!-- 第三方框架日志级别 -->
    <!-- ======================================== -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.cloud" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.springframework.data" level="INFO"/>

    <!-- Hibernate/MyBatis -->
    <logger name="org.hibernate" level="INFO"/>
    <logger name="com.baomidou.mybatisplus" level="INFO"/>

    <!-- Kafka -->
    <logger name="org.apache.kafka" level="INFO"/>
    <logger name="org.springframework.kafka" level="INFO"/>

    <!-- Redis -->
    <logger name="io.lettuce" level="WARN"/>
    <logger name="org.redisson" level="INFO"/>

    <!-- Netty -->
    <logger name="io.netty" level="INFO"/>

    <!-- Nacos -->
    <logger name="com.alibaba.nacos" level="INFO"/>

    <!-- ======================================== -->
    <!-- 开发环境配置 -->
    <!-- ======================================== -->
    <springProfile name="dev,local">
        <root level="DEBUG">
            <appender-ref ref="ASYNC_PRETTY"/>
        </root>

        <!-- 开发时打印 SQL -->
        <logger name="com.openiot" level="DEBUG"/>
        <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
    </springProfile>

    <!-- ======================================== -->
    <!-- 测试环境配置 -->
    <!-- ======================================== -->
    <springProfile name="test">
        <root level="DEBUG">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
        <logger name="com.openiot" level="DEBUG"/>
    </springProfile>

    <!-- ======================================== -->
    <!-- 生产环境配置 -->
    <!-- ======================================== -->
    <springProfile name="prod,production">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
        <logger name="com.openiot" level="INFO"/>
    </springProfile>

    <!-- ======================================== -->
    <!-- 默认配置 (如果未指定 profile) -->
    <!-- ======================================== -->
    <springProfile name="!dev &amp; !local &amp; !test &amp; !prod &amp; !production">
        <root level="INFO">
            <appender-ref ref="ASYNC_PRETTY"/>
        </root>
        <logger name="com.openiot" level="DEBUG"/>
    </springProfile>

</configuration>
